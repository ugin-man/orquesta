{
  "$id": "specialist-plan-v2",
  "type": "object",
  "required": ["schema_version", "source_understanding_hash", "source_completion_map_revision", "first_executable_batch", "selected_specialists", "future_candidates", "approval_source"],
  "properties": {
    "schema_version": { "const": 2 },
    "source_understanding_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "source_completion_map_revision": { "type": "integer", "minimum": 0 },
    "first_executable_batch": { "type": "array", "items": { "type": "string", "pattern": ".+" } },
    "selected_specialists": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role_id", "quantity", "line_id", "team_id", "reason_codes", "task_ids"],
        "properties": {
          "role_id": { "type": "string", "pattern": ".+" },
          "quantity": { "type": "integer", "minimum": 1 },
          "line_id": { "anyOf": [{ "type": "string", "pattern": ".+" }, { "type": "null" }] },
          "team_id": { "type": "string", "pattern": ".+" },
          "reason_codes": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[A-Z_]+$" } },
          "task_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": ".+" } }
        },
        "additionalProperties": false
      }
    },
    "future_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role_id", "activation_condition"],
        "properties": {
          "role_id": { "type": "string", "pattern": ".+" },
          "activation_condition": { "type": "string", "pattern": ".+" }
        },
        "additionalProperties": false
      }
    },
    "approval_source": { "enum": ["setup_confirmation", "user_approval"] }
  },
  "additionalProperties": false
}
