{
  "$id": "audition-result",
  "type": "object",
  "required": ["audition_plan_id", "observed_codex_profile", "steps", "side_effects", "evidence_refs", "verdict", "cleanup_evidence"],
  "properties": {
    "audition_plan_id": { "type": "string", "pattern": "^AP-[a-f0-9]{12}$" },
    "observed_codex_profile": { "type": "string", "pattern": ".+" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step", "status"],
        "properties": {
          "step": { "type": "string", "pattern": ".+" },
          "status": { "enum": ["passed", "failed", "skipped"] }
        },
        "additionalProperties": false
      }
    },
    "side_effects": { "type": "array", "items": { "type": "string", "pattern": ".+" } },
    "evidence_refs": { "type": "array", "items": { "type": "string", "pattern": ".+" } },
    "verdict": { "enum": ["passed", "failed", "inconclusive"] },
    "cleanup_evidence": { "type": "array", "items": { "type": "string", "pattern": ".+" } }
  },
  "additionalProperties": false
}
